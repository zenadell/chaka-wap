# ===========================================================================
# Chaka WhatsApp Crawler — environment configuration
# Copy to ".env" for local dev. In production set these as platform secrets
# (e.g. `fly secrets set KEY=value`) — never commit real values.
# ===========================================================================

# --- Runtime ---
NODE_ENV=production
PORT=3000
# Public base URL of the deployment (used for OpenRouter referer headers).
PUBLIC_URL=https://your-app.fly.dev

# --- Security (REQUIRED in production) ---
# Long random string used to sign JWTs. Generate with: openssl rand -hex 32
JWT_SECRET=
# Email address that is granted the admin role.
ADMIN_EMAIL=you@example.com
# Comma-separated list of origins allowed to call the API / Socket.io.
# Required in production; leave blank in dev to allow all.
CORS_ORIGINS=https://your-app.fly.dev

# --- AI providers ---
# Default text/agentic engine.
# Options: deepseek | openrouter | gemini | groq | qwen | chaka
ACTIVE_API=deepseek

# DeepSeek — PRIMARY engine, direct paid API (no OpenRouter middleman).
# Get the key from https://platform.deepseek.com.
# Model "deepseek-chat" = NON-THINKING V4 Flash: fast + ~10x cheaper than thinking
# mode, ideal for short chat replies. (Use "deepseek-reasoner" for agentic/tool work.)
# ⚠️ "deepseek-chat" retires 2026-07-24 — re-verify non-thinking on deepseek-v4-flash before then.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenRouter — optional fallback route to the same model family.
OPENROUTER_API_KEY=
OPENROUTER_TEXT_MODEL=deepseek/deepseek-v4-flash

# Gemini — used ONLY for vision (images) and audio (voice-note transcription).
# Comma-separated keys are supported for rotation. Leave blank to disable
# image understanding and voice transcription. Hosted by the platform — users
# never supply their own keys.
GEMINI_API_KEYS=

# Optional alternate providers / failover.
GROQ_API_KEY=
QWEN_ENDPOINT=http://localhost:8000/api/chat

# --- Google OAuth (optional — enables "Sign in with Google") ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
